-- .busted - busted test runner config
--
-- Run from repo root:  bash scripts/run_tests.sh   (Windows/MSYS2 wrapper)
--                  or: busted                       (POSIX / CI)

return {
    default = {
        verbose = true,
        ROOT = { "spec/" },
        pattern = "_spec",
        lpath  = "./?.lua;./?/init.lua;./spec/?.lua",
    },
}
